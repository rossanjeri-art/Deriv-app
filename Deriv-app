<!DOCTYPE html>
<html>
<head>
  <title>Deriv Tick Intelligence</title>
  <style>
    body {
      font-family: Arial;
      background: #0f172a;
      color: white;
      text-align: center;
      padding: 20px;
    }

    .card {
      background: #1e293b;
      padding: 15px;
      margin: 10px;
      border-radius: 10px;
    }

    .big {
      font-size: 40px;
      font-weight: bold;
    }

    .green { color: #22c55e; }
    .red { color: #ef4444; }
    .orange { color: #f59e0b; }
  </style>
</head>

<body>

<h2>Deriv Tick Intelligence (1-Tick)</h2>

<div class="card">
  <div>Last Digit</div>
  <div id="last" class="big">-</div>
</div>

<div class="card">
  <div>Confidence</div>
  <div id="confidence" class="big">0</div>
</div>

<div class="card">
  <div>Signal</div>
  <div id="signal">WAIT</div>
</div>

<div class="card">
  <div>Digit Frequency</div>
  <div id="freq"></div>
</div>

<script>
let ws = new WebSocket("wss://ws.derivws.com/websockets/v3");

let counts = Array(10).fill(0);
let ticks = [];

ws.onopen = function () {
  ws.send(JSON.stringify({
    ticks: "R_75",
    subscribe: 1
  }));
};

ws.onmessage = function (msg) {
  let data = JSON.parse(msg.data);

  if (data.tick) {
    let price = data.tick.quote;
    let digit = parseInt(String(Math.floor(price)).slice(-1));

    document.getElementById("last").innerText = digit;

    counts[digit]++;
    ticks.push(digit);

    if (ticks.length > 100) ticks.shift();

    updateUI();
  }
};

function updateUI() {
  let total = ticks.length;

  let expected = total / 10;
  let imbalance = 0;

  for (let i = 0; i < 10; i++) {
    imbalance += Math.abs(counts[i] - expected);
  }

  let confidence = Math.min(100, (imbalance / total) * 120);

  let hotDigit = counts.indexOf(Math.max(...counts));

  let signal = "NO TRADE";

  if (confidence > 70) {
    signal = "HIGH BIAS → DIGIT " + hotDigit;
  } else if (confidence > 45) {
    signal = "WATCH DIGIT " + hotDigit;
  }

  document.getElementById("confidence").innerText = confidence.toFixed(1);

  document.getElementById("signal").innerText = signal;

  document.getElementById("signal").className =
    confidence > 70 ? "green big" :
    confidence > 45 ? "orange big" : "red big";

  let html = "";
  for (let i = 0; i < 10; i++) {
    html += `Digit ${i}: ${counts[i]}<br>`;
  }

  document.getElementById("freq").innerHTML = html;
}
</script>

</body>
</html>
